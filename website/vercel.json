{
  "rewrites": [
    { "source": "/privacy", "destination": "/politica-de-privacidade.html" },
    { "source": "/privacidade", "destination": "/politica-de-privacidade.html" },
    { "source": "/delete-account", "destination": "/excluir-conta.html" },
    { "source": "/excluir-conta", "destination": "/excluir-conta.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
